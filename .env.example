# ─────────────────────────────────────────────────────────────────────────────
#  VAJRA — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application Security ──────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
ADMIN_PASSWORD=vajra-admin-2026

# ─────────────────────────────────────────────────────────────────────────────
#  AI PROVIDER — Choose one below
#
#  FREE OPTIONS (no credit card needed):
#    1. Groq       — fastest, 14,400 req/day free   → https://console.groq.com
#    2. Ollama     — 100% local, no internet, free   → https://ollama.com
#    3. OpenRouter — some models are free            → https://openrouter.ai
#    4. Gemini     — free tier (create fresh project)→ https://aistudio.google.com
#
#  PAID OPTIONS:
#    5. Anthropic  — Claude models (best quality)    → https://console.anthropic.com
#    6. OpenAI     — GPT-4o and others               → https://platform.openai.com
#    7. Grok       — xAI models                      → https://console.x.ai
#    8. Mistral    — Mistral models                  → https://console.mistral.ai
#    9. DeepSeek   — no free tier anymore            → https://platform.deepseek.com
#   10. Together   — various open models             → https://api.together.xyz
#
#  Uncomment ONE block below and add your API key.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. GROQ — Recommended free option ────────────────────────────────────────
# Free: 14,400 requests/day, no credit card needed
# Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# Get key: https://console.groq.com → API Keys → Create key (2 minutes)
# AI_PROVIDER=groq
# AI_API_KEY=gsk_your-groq-key-here
# AI_MODEL=llama-3.3-70b-versatile

# ── 2. OLLAMA — 100% local, completely free ───────────────────────────────────
# Free: runs on your machine, no internet, no key, no limits
# Requires: https://ollama.com → install → run: ollama pull llama3.1:8b
# Good model for low-spec machines: llama3.2:3b (2GB RAM)
# Good model for quality:          llama3.1:8b (8GB RAM)
# AI_PROVIDER=ollama
# AI_API_KEY=not-required
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1:8b

# ── 3. OPENROUTER — free models available ────────────────────────────────────
# Free: many models marked free on https://openrouter.ai/models?q=free
# Get key: https://openrouter.ai → Sign up → Keys
# Free model examples: meta-llama/llama-3.1-8b-instruct:free
#                      mistralai/mistral-7b-instruct:free
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-your-key-here
# AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── 4. GOOGLE GEMINI — free tier ─────────────────────────────────────────────
# Free: 1,500 req/day — create a FRESH Google project to avoid quota errors
# Install first: pip3 install google-genai --break-system-packages
# Get key: https://aistudio.google.com → Get API Key → Create in new project
# AI_PROVIDER=gemini
# AI_API_KEY=your-gemini-key-here
# AI_MODEL=gemini-2.0-flash-lite

# ── 5. ANTHROPIC — Claude (paid) ─────────────────────────────────────────────
# Best report quality. Pay-per-use, no monthly fee.
# Get key: https://console.anthropic.com
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-your-key-here
# AI_MODEL=claude-sonnet-4-6

# ── 6. OPENAI — ChatGPT (paid) ────────────────────────────────────────────────
# Get key: https://platform.openai.com/api-keys
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-openai-key-here
# AI_MODEL=gpt-4o

# ── 7. XAI GROK (paid) ───────────────────────────────────────────────────────
# Get key: https://console.x.ai
# AI_PROVIDER=grok
# AI_API_KEY=xai-your-key-here
# AI_MODEL=grok-2

# ── 8. MISTRAL AI (paid) ─────────────────────────────────────────────────────
# Get key: https://console.mistral.ai
# AI_PROVIDER=mistral
# AI_API_KEY=your-mistral-key-here
# AI_MODEL=mistral-large-latest

# ── 9. DEEPSEEK (paid — no free tier) ────────────────────────────────────────
# Very cheap (~$0.14/million tokens) but requires balance top-up
# Get key: https://platform.deepseek.com
# AI_PROVIDER=deepseek
# AI_API_KEY=your-deepseek-key-here
# AI_MODEL=deepseek-chat

# ── 10. TOGETHER AI (paid) ───────────────────────────────────────────────────
# Get key: https://api.together.xyz
# AI_PROVIDER=together
# AI_API_KEY=your-together-key-here
# AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── Self-hosted Proxy (LiteLLM, vLLM, Azure OpenAI, etc.) ────────────────────
# AI_PROVIDER=openai
# AI_API_KEY=your-proxy-token
# AI_BASE_URL=https://your-gateway.example.com/v1
# AI_MODEL=your-model-name
# SKIP_SSL_VERIFY=true

# ── TLS / SSL ─────────────────────────────────────────────────────────────────
SKIP_SSL_VERIFY=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
HTTPS=false
