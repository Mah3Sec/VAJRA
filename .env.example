# ─────────────────────────────────────────────────────────────────────────────
#  VAJRA — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application Security ──────────────────────────────────────────────────────
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# Default admin password — change immediately after first login
ADMIN_PASSWORD=vajra-admin-2026

# ── AI Provider ───────────────────────────────────────────────────────────────
# Pick ONE provider block below. Comment out all others.
# AI_BASE_URL is optional for providers with a default — set it to override.

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Models: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
# Docs:   https://docs.anthropic.com
AI_PROVIDER=anthropic
AI_API_KEY=sk-ant-your-key-here
AI_BASE_URL=https://api.anthropic.com
AI_MODEL=claude-sonnet-4-6

# ── OpenAI (ChatGPT) ──────────────────────────────────────────────────────────
# Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, o1-preview
# Docs:   https://platform.openai.com/docs
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-openai-key
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Models: gemini-1.5-pro, gemini-1.5-flash, gemini-2.0-flash
# Docs:   https://ai.google.dev/api
# Install: pip3 install google-generativeai --break-system-packages
# AI_PROVIDER=gemini
# AI_API_KEY=AIza-your-google-ai-key
# AI_MODEL=gemini-1.5-pro

# ── xAI Grok ─────────────────────────────────────────────────────────────────
# Models: grok-2, grok-2-mini, grok-beta
# Docs:   https://docs.x.ai/api
# AI_PROVIDER=grok
# AI_API_KEY=xai-your-key-here
# AI_MODEL=grok-2

# ── Mistral AI ────────────────────────────────────────────────────────────────
# Models: mistral-large-latest, mistral-medium-latest, codestral-latest
# Docs:   https://docs.mistral.ai
# AI_PROVIDER=mistral
# AI_API_KEY=your-mistral-key
# AI_MODEL=mistral-large-latest

# ── Cohere ────────────────────────────────────────────────────────────────────
# Models: command-r-plus, command-r, command
# Docs:   https://docs.cohere.com
# AI_PROVIDER=cohere
# AI_API_KEY=your-cohere-key
# AI_MODEL=command-r-plus

# ── Groq (fast inference) ─────────────────────────────────────────────────────
# Models: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
# Docs:   https://console.groq.com/docs
# AI_PROVIDER=groq
# AI_API_KEY=gsk_your-groq-key
# AI_MODEL=llama-3.3-70b-versatile

# ── Together AI ───────────────────────────────────────────────────────────────
# Models: meta-llama/Llama-3.3-70B-Instruct-Turbo, mistralai/Mixtral-8x7B
# Docs:   https://docs.together.ai
# AI_PROVIDER=together
# AI_API_KEY=your-together-key
# AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Access 200+ models from one API key.
# Docs:   https://openrouter.ai/docs
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-your-key
# AI_MODEL=anthropic/claude-3.5-sonnet

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# Models: llama3.1:70b, mistral:7b, deepseek-r1:14b, phi4, etc.
# Docs:   https://ollama.com
# AI_PROVIDER=ollama
# AI_API_KEY=not-required
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.1:70b

# ── DeepSeek ──────────────────────────────────────────────────────────────────
# Models: deepseek-chat, deepseek-coder
# Docs:   https://platform.deepseek.com/api-docs
# AI_PROVIDER=deepseek
# AI_API_KEY=your-deepseek-key
# AI_MODEL=deepseek-chat

# ── Self-hosted / Custom Proxy (LiteLLM, vLLM, etc.) ────────────────────────
# Use openai or anthropic provider depending on the proxy's wire format.
# AI_PROVIDER=openai
# AI_API_KEY=your-proxy-token
# AI_BASE_URL=https://your-gateway.example.com/v1
# AI_MODEL=your-model-name
# SKIP_SSL_VERIFY=true    # uncomment if using self-signed TLS cert

# ── TLS / SSL ─────────────────────────────────────────────────────────────────
SKIP_SSL_VERIFY=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000

# Set to true when serving VAJRA behind HTTPS (enables Secure cookie flag).
HTTPS=false
